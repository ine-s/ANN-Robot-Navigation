\section{Exercice d'application : Robot Thymio II}
%===========================================

\subsection{Comportement A}
\textbf{Objectif :} Le robot avance si les 2 capteurs arrière détectent un obstacle (opérateur AND).

\textbf{Capteurs utilisés :} \texttt{prox.horizontal[5]} et \texttt{prox.horizontal[6]}

\begin{lstlisting}
capt_gauche = th[node_id]["prox.horizontal"][5]
capt_droit = th[node_id]["prox.horizontal"][6]
x1 = 1 if capt_gauche > SEUIL else 0
x2 = 1 if capt_droit > SEUIL else 0
y = perceptron(x1, x2, -1.5, 1, 1)  # AND

if y == 1:
    # Avancer
    th[node_id]["motor.left.target"] = 100
    th[node_id]["motor.right.target"] = 100
\end{lstlisting}

\textbf{Résultat :} Le robot reste immobile. Quand on place un obstacle derrière lui (détecté par les 2 capteurs), il avance.

\subsection{Comportement B}
\textbf{Objectif :} Le robot avance si les 2 capteurs au sol détectent une surface (opérateur AND).

\textbf{Capteurs utilisés :} \texttt{prox.ground.delta[0]} et \texttt{prox.ground.delta[1]}

\textbf{Résultat :} Le robot avance sur une surface. S'il arrive au bord (vide détecté par un capteur), il s'arrête.

